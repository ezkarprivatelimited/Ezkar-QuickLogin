{
  "manifest_version": 3,
  "name": "Ezkar QuickLogin",
  "version": "1.0",
  "description": "Streamlines logging into the GST portal directly from the Ezkar dashboard.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "scripting",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5173/*",
    "https://*.ezkar.in/*",
    "https://services.gst.gov.in/*",
    "https://eportal.incometax.gov.in/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ezkar QuickLogin",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://*.ezkar.in/*"
      ],
      "js": [
        "dashboard-script.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://services.gst.gov.in/services/login"
      ],
      "js": [
        "gst-script.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://eportal.incometax.gov.in/iec/foservices/*"
      ],
      "js": [
        "it-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}