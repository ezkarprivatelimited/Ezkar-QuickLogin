{
  "manifest_version": 3,
  "name": "Ezkar QuickLogin",
  "version": "1.0",
  "description": "Streamlines logging into the GST portal directly from the Ezkar dashboard.",
  "permissions": [
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:5173/*",
    "https://*.ezkar.in/*",
    "https://services.gst.gov.in/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ezkar QuickLogin"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://*.ezkar.in/*"
      ],
      "js": [
        "dashboard-script.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://services.gst.gov.in/services/login"
      ],
      "js": [
        "gst-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}